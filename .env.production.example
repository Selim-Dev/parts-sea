# Production Environment Variables
# Copy this to .env on your server and fill in the values

# Database
MONGODB_URI=mongodb://localhost:27017/spare-parts
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/spare_parts

# JWT Secret (CHANGE THIS!)
JWT_SECRET=change-this-to-a-random-secure-string-min-32-chars

# Node Environment
NODE_ENV=production

# API URLs (for frontend apps)
NEXT_PUBLIC_API_URL=https://api.bahr-alqeta3.store
VITE_API_URL=https://api.bahr-alqeta3.store

# Email (if using email features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Redis (if using caching)
# REDIS_URL=redis://redis:6379
