import { DataSource } from 'typeorm';
import * as bcrypt from 'bcrypt';
import { User } from '../users/user.entity.js';
import { Part } from '../parts/part.entity.js';
import { Order } from '../orders/order.entity.js';
import { OrderItem } from '../orders/order-item.entity.js';

const dataSource = new DataSource({
  type: 'better-sqlite3',
  database: 'data/spare-parts.db',
  entities: [User, Part, Order, OrderItem],
  synchronize: true,
});

async function seed() {
  await dataSource.initialize();
  console.log('✅ تم الاتصال بقاعدة البيانات');

  const userRepo = dataSource.getRepository(User);
  const partRepo = dataSource.getRepository(Part);

  // --- Seed Users ---
  const existingAdmin = await userRepo.findOneBy({ username: 'admin' });
  if (!existingAdmin) {
    const admin = userRepo.create({
      username: 'admin',
      password: await bcrypt.hash('admin123', 10),
      role: 'admin',
      isActive: true,
    });
    await userRepo.save(admin);
    console.log('✅ تم إضافة مستخدم الإدارة (admin)');
  } else {
    console.log('⏭️  مستخدم الإدارة موجود مسبقاً');
  }

  const existingShop = await userRepo.findOneBy({ username: 'shop1' });
  if (!existingShop) {
    const shop = userRepo.create({
      username: 'shop1',
      password: await bcrypt.hash('shop123', 10),
      role: 'shop',
      shopName: 'محل النور',
      isActive: true,
    });
    await userRepo.save(shop);
    console.log('✅ تم إضافة مستخدم المحل (shop1)');
  } else {
    console.log('⏭️  مستخدم المحل موجود مسبقاً');
  }

  // --- Seed Parts ---
  const existingParts = await partRepo.count();
  if (existingParts === 0) {
    const parts: Partial<Part>[] = [
      {
        partNumber: 'OIL-FLT-001',
        name: 'فلتر زيت المحرك',
        price: 25.0,
        description: 'فلتر زيت عالي الجودة يناسب معظم السيارات اليابانية والكورية',
        stock: 150,
        category: 'فلاتر',
        brand: 'دينسو',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRLwoV6R0T3-nuhfj2yfJBkCRSeTXEq3f9rJQ&s',
      },
      {
        partNumber: 'AIR-FLT-002',
        name: 'فلتر هواء',
        price: 35.0,
        description: 'فلتر هواء للمحرك يضمن تدفق هواء نظيف وأداء أفضل',
        stock: 120,
        category: 'فلاتر',
        brand: 'بوش',
        imageUrl: 'https://garageilla.com/cdn/shop/files/WhatsAppImage2024-01-17at12.38.58PM.jpg?v=1737567512',
      },
      {
        partNumber: 'SPK-PLG-003',
        name: 'شمعات إشعال',
        price: 18.0,
        description: 'طقم شمعات إشعال إيريديوم عالية الأداء — 4 قطع',
        stock: 200,
        category: 'كهربائيات',
        brand: 'دينسو',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTpo2Ii-KOlFEtXOCCjxfxgSeVJiU44TZkw8g&s',
      },
      {
        partNumber: 'BRK-FRT-004',
        name: 'طقم فرامل أمامي',
        price: 180.0,
        description: 'طقم فحمات فرامل أمامية سيراميك مقاومة للحرارة',
        stock: 60,
        category: 'فرامل',
        brand: 'بريمبو',
        imageUrl: 'https://auto.ahram.org.eg/Media/News/2024/1/21/19_2024-638414464886852136-685.jpg',
      },
      {
        partNumber: 'BRK-RER-005',
        name: 'طقم فرامل خلفي',
        price: 150.0,
        description: 'طقم فحمات فرامل خلفية عالية الجودة',
        stock: 55,
        category: 'فرامل',
        brand: 'بوش',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRIyjJD_d0a0c7VDpAl0AQBUq__6RH1UJj3zA&s',
      },
      {
        partNumber: 'BAT-070-006',
        name: 'بطارية 70 أمبير',
        price: 350.0,
        description: 'بطارية سيارة 70 أمبير ضمان سنتين — مناسبة للأجواء الحارة',
        stock: 40,
        category: 'كهربائيات',
        brand: 'بوش',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRLwoV6R0T3-nuhfj2yfJBkCRSeTXEq3f9rJQ&s',
      },
      {
        partNumber: 'BLT-AC-007',
        name: 'سير مكيف',
        price: 45.0,
        description: 'سير مكيف مطاطي متين يناسب أغلب الموديلات',
        stock: 90,
        category: 'أسلاك وسيور',
        brand: 'جيتس',
        imageUrl: 'https://garageilla.com/cdn/shop/files/WhatsAppImage2024-01-17at12.38.58PM.jpg?v=1737567512',
      },
      {
        partNumber: 'WTR-PMP-008',
        name: 'مضخة ماء',
        price: 220.0,
        description: 'مضخة ماء للمحرك تضمن تبريد فعال ومنع ارتفاع الحرارة',
        stock: 30,
        category: 'تبريد',
        brand: 'أصلي',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTpo2Ii-KOlFEtXOCCjxfxgSeVJiU44TZkw8g&s',
      },
      {
        partNumber: 'RAD-COL-009',
        name: 'رديتر تبريد',
        price: 450.0,
        description: 'رديتر تبريد ألمنيوم خفيف الوزن وعالي الكفاءة',
        stock: 20,
        category: 'تبريد',
        brand: 'أصلي',
        imageUrl: 'https://auto.ahram.org.eg/Media/News/2024/1/21/19_2024-638414464886852136-685.jpg',
      },
      {
        partNumber: 'O2-SEN-010',
        name: 'حساس أكسجين',
        price: 160.0,
        description: 'حساس أكسجين أصلي يحسّن استهلاك الوقود وأداء المحرك',
        stock: 45,
        category: 'كهربائيات',
        brand: 'دينسو',
        imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRIyjJD_d0a0c7VDpAl0AQBUq__6RH1UJj3zA&s',
      },
    ];

    await partRepo.save(parts.map((p) => partRepo.create(p)));
    console.log('✅ تم إضافة 10 قطع غيار تجريبية');
  } else {
    // Update existing parts with imageUrl if missing
    const allParts = await partRepo.find();
    const backfillMap: Record<string, { imageUrl: string; category: string; brand: string }> = {
      'OIL-FLT-001': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRLwoV6R0T3-nuhfj2yfJBkCRSeTXEq3f9rJQ&s', category: 'فلاتر', brand: 'دينسو' },
      'AIR-FLT-002': { imageUrl: 'https://garageilla.com/cdn/shop/files/WhatsAppImage2024-01-17at12.38.58PM.jpg?v=1737567512', category: 'فلاتر', brand: 'بوش' },
      'SPK-PLG-003': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTpo2Ii-KOlFEtXOCCjxfxgSeVJiU44TZkw8g&s', category: 'كهربائيات', brand: 'دينسو' },
      'BRK-FRT-004': { imageUrl: 'https://auto.ahram.org.eg/Media/News/2024/1/21/19_2024-638414464886852136-685.jpg', category: 'فرامل', brand: 'بريمبو' },
      'BRK-RER-005': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRIyjJD_d0a0c7VDpAl0AQBUq__6RH1UJj3zA&s', category: 'فرامل', brand: 'بوش' },
      'BAT-070-006': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRLwoV6R0T3-nuhfj2yfJBkCRSeTXEq3f9rJQ&s', category: 'كهربائيات', brand: 'بوش' },
      'BLT-AC-007': { imageUrl: 'https://garageilla.com/cdn/shop/files/WhatsAppImage2024-01-17at12.38.58PM.jpg?v=1737567512', category: 'أسلاك وسيور', brand: 'جيتس' },
      'WTR-PMP-008': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTpo2Ii-KOlFEtXOCCjxfxgSeVJiU44TZkw8g&s', category: 'تبريد', brand: 'أصلي' },
      'RAD-COL-009': { imageUrl: 'https://auto.ahram.org.eg/Media/News/2024/1/21/19_2024-638414464886852136-685.jpg', category: 'تبريد', brand: 'أصلي' },
      'O2-SEN-010': { imageUrl: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRIyjJD_d0a0c7VDpAl0AQBUq__6RH1UJj3zA&s', category: 'كهربائيات', brand: 'دينسو' },
    };
    let updated = 0;
    for (const part of allParts) {
      const fill = backfillMap[part.partNumber];
      if (!fill) continue;
      let changed = false;
      if (!part.imageUrl && fill.imageUrl) { part.imageUrl = fill.imageUrl; changed = true; }
      if (!part.category && fill.category) { part.category = fill.category; changed = true; }
      if (!part.brand && fill.brand) { part.brand = fill.brand; changed = true; }
      if (changed) { await partRepo.save(part); updated++; }
    }
    if (updated > 0) {
      console.log(`✅ تم تحديث بيانات ${updated} قطعة`);
    } else {
      console.log(`⏭️  يوجد ${existingParts} قطعة مسبقاً — تم تخطي الإضافة`);
    }
  }

  await dataSource.destroy();
  console.log('🎉 اكتمل الـ seed بنجاح');
}

seed().catch((err) => {
  console.error('❌ خطأ أثناء الـ seed:', err);
  process.exit(1);
});
